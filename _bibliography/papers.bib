@article{PhysRev.47.777,
  abbr              = {IJRS},
  title             = {The possible contribution of marine heatwaves on the declining healthy coral reef cover in Nusa Dua, Bali},
  author            = {Prasetyo*, M.A.H., Wijayanti, D.P., Haryanti, D., Suga, T., Puryajati, A.D., Yasunaka, S., Wirasatriya, A., Fauziah, S., Putranto, R.T., Adiwira, H., Rodriguez, M.V.B., Wetchayont, P., Abdillah, M.R., and Susanto R.D.},
  abstract          = {Historically, Southern Java to Bali is the area within the Indonesian Seas with the most intense and long duration of marine heatwave (MHW). Nusa Dua, Bali located in Southern Bali, is one of the regions filled with diverse coral reef ecosystems that previously had a history of bleaching phenomenon. This study aims to investigate how MHW may be contributing to the decrease in healthy coral cover by combining historical remote sensing methods with field observations. MHW detection was done using the 90th percentile of sea surface temperature (SST) data collected over 40 years from the Operational Sea Surface Temperature and Ice Analysis (OSTIA). Historical benthic mapping of healthy coral coverage was done using Sentinel 2 imageries and classified using random forest algorithm after series of in-air and water corrections from 2015 – 2022. Additionally, field observation was conducted for ground truth validation and to obtain the percentage of healthy coral coverage using the Line Intercept Transect (LIT) method in 2022 and 2023 along with the retrieval of water quality parameters. The result indicates that these MHWs occurred over the west and east monsoon periods, with the most destructive one happening in the west monsoon period, with the mean intensity absolute > 29°C. Significant decrease in healthy coral coverage was observed, with the most severe decline in 2016 resulting in a total loss of 39.7% from the initial coverage, with massive Porites sp. reported to be one of the species impacted. The east monsoon period acts as the recovery period for the coral reefs since the temperature is lower (24–25°C), due to upwelling occurrence in the area based on vertical distribution of temperature during this period. The observational data further support the impact of MHWs on the decrease in healthy coral cover in Nusa Dua, Bali.},
  journal           = {International Journal of Remote Sensing},
  location          = {United Kingdom},
  volume            = {},
  issue             = {},
  pages             = {},
